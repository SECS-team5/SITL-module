# ============================================================
#  ПРОФИЛИ: какие локальные сервисы поднимать
# ============================================================
# kafka        — локальный Kafka + Zookeeper
# mqtt         — локальный Mosquitto
# local-redis  — локальный Redis
#
# Всё локально (Kafka):   COMPOSE_PROFILES=kafka,local-redis
# Всё внешнее:            COMPOSE_PROFILES=
# ============================================================
COMPOSE_PROFILES=kafka,local-redis

# ============================================================
#  БРОКЕР
# ============================================================
BROKER_BACKEND=kafka
KAFKA_SERVERS=kafka:29092

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1

# ============================================================
#  REDIS
# ============================================================
REDIS_URL=redis://redis:6379

# ============================================================
#  ТОПИКИ
# ============================================================
INPUT_TOPICS=sitl.commands,sitl-drone-home
COMMAND_TOPIC=sitl.commands
HOME_TOPIC=sitl-drone-home
VERIFIED_COMMAND_TOPIC=sitl.verified-commands
VERIFIED_HOME_TOPIC=sitl.verified-home
POSITION_REQUEST_TOPIC=sitl.telemetry.request
POSITION_RESPONSE_TOPIC=sitl.telemetry.response

# ============================================================
#  ПАРАМЕТРЫ
# ============================================================
UPDATE_FREQUENCY_HZ=10.0
STATE_TTL_SEC=7200